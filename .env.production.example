# 由 deploy/setup-vps.sh 自动生成，也可手动复制为 .env

# 基础设施：true=本项目新建容器，false=复用已有
USE_BUILTIN_REDIS=true
USE_BUILTIN_POSTGRES=true

REDIS_CONNECTION=redis:6379,abortConnect=false
POSTGRES_CONNECTION=Host=postgres;Port=5432;Database=websearch;Username=websearch;Password=change-me
POSTGRES_PASSWORD=change-me-to-a-strong-password

SEARXNG_SECRET_KEY=change-me-to-a-random-string

FIRECRAWL_API_KEY=
JINA_API_KEY=

CACHE_SEARCH_TTL=7200
CACHE_SCRAPE_TTL=86400

API_DOMAIN=api.yourdomain.com
CERTBOT_EMAIL=you@example.com
NGINX_SITE_NAME=websearch
WEBSEARCH_API_URL=https://api.yourdomain.com

# 复用宿主机已有 Redis/PostgreSQL 时示例：
# USE_BUILTIN_REDIS=false
# REDIS_CONNECTION=host.docker.internal:6379,abortConnect=false
# USE_BUILTIN_POSTGRES=false
# POSTGRES_CONNECTION=Host=host.docker.internal;Port=5432;Database=websearch;Username=websearch;Password=your-password
