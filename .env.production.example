# Copy to .env on the VPS: cp .env.production.example .env

# PostgreSQL (required — change password!)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Optional external API keys (scrape fallback)
FIRECRAWL_API_KEY=
JINA_API_KEY=

# Cache TTL (seconds)
CACHE_SEARCH_TTL=7200
CACHE_SCRAPE_TTL=86400

# SearXNG secret (change in production)
SEARXNG_SECRET_KEY=change-me-to-a-random-string

# Public URL of your API (for documentation only)
WEBSEARCH_API_URL=https://api.yourdomain.com
