# WebSearch — 环境变量模板
# 复制此文件: cp .env.example .env
# deploy.sh 会自动生成随机 SEARXNG_SECRET / POSTGRES_PASSWORD，
# 只需手动填写可选的 API Key。

# ── 对外端口（改这里即可换端口，无需动其他文件）────────────────────────
APP_PORT=18900

# ── 必填（deploy.sh 自动生成随机值）────────────────────────────────────
SEARXNG_SECRET=change-me-with-a-random-hex-string
POSTGRES_PASSWORD=change-me-with-a-random-password

# ── 可选：付费 API 兜底 ─────────────────────────────────────────────────
# 搜索兜底：SearXNG 结果 < 4 条时触发（留空则跳过）
TAVILY_API_KEY=

# 抓取兜底：crawl-svc 返回失败时触发（留空则跳过）
FIRECRAWL_API_KEY=

# ── 可选：缓存 TTL（秒）─────────────────────────────────────────────────
CACHE_SEARCH_TTL=7200
CACHE_SCRAPE_TTL=86400
