# WebSearch — 环境变量模板
# 首次部署: sudo bash install.sh（向导会交互式填写并生成此文件）
# 手动填写: cp .env.example .env，然后编辑下方变量

# ── 对外端口 ─────────────────────────────────────────────────────────────
APP_PORT=18900

# ── 基础设施连接（install.sh 向导自动填写）──────────────────────────────
USE_BUILTIN_REDIS=true
USE_BUILTIN_POSTGRES=true
REDIS_CONNECTION="localhost:6379,abortConnect=false"
POSTGRES_CONNECTION="Host=localhost;Port=5432;Database=websearch;Username=websearch;Password=change-me"
POSTGRES_PASSWORD=change-me
SEARXNG_SECRET=change-me-with-a-random-hex-string

# ── 可选：付费 API 兜底 ─────────────────────────────────────────────────
# 搜索兜底：SearXNG 结果 < 4 条或均分 < 0.3 时触发（留空则跳过）
TAVILY_API_KEY=

# 抓取兜底：crawl-svc 返回失败时触发（留空则跳过）
FIRECRAWL_API_KEY=

# ── 可选：缓存与内容配置 ─────────────────────────────────────────────────
CACHE_SEARCH_TTL=7200
CACHE_SCRAPE_TTL=86400
SCRAPE_MAX_CHARS=8000
